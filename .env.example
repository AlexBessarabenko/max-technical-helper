YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_LLM_MODEL=deepseek-v4-flash
MAX_BOT_TOKEN=
# Режим получения обновлений MAX: polling (dev, по умолчанию) или webhook (prod)
MAX_MODE=polling
# Для webhook-режима: публичный HTTPS URL без пути, секрет и порт сервера
WEBHOOK_URL=
WEBHOOK_PATH=/webhook/max
WEBHOOK_SECRET=
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3000
